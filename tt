#!/bin/bash
# Token Tracker - 简化版命令行工具

TOKEN_FILE="$(dirname "$0")/token.txt"
BUDGET=7
HOURLY_BUDGET=1.4

# 颜色
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# 显示帮助
show_help() {
    echo -e "${BLUE}Token Tracker - 简化版${NC}"
    echo ""
    echo "使用方法:"
    echo "  tt                - 查看统计"
    echo "  tt '任务'         - 记录任务（自动提示输入token）"
    echo "  tt '任务' i o    - 记录任务（i=输入token, o=输出token）"
    echo "  tt -h            - 显示帮助"
    echo ""
    echo "示例:"
    echo "  tt '修复登录bug'"
    echo "  tt '写文档' 2000 500"
}

# 计算成本
calc_cost() {
    local input=$1
    local output=$2
    # 使用 scale=4 精确计算，保留4位小数
    echo "scale=4; ($input/1000000)*3 + ($output/1000000)*15" | bc
}

# 记录任务（带优化建议检查）
record_task() {
    local name="$1"
    local input=${2:-0}
    local output=${3:-0}
    local suggestion=""

    # 如果没有提供 token，提示输入
    if [ "$input" = "0" ] && [ "$2" = "" ]; then
        echo -n "输入token数: "
        read input
        echo -n "输出token数: "
        read output
    fi

    local cost=$(calc_cost "$input" "$output")
    local timestamp=$(date -Iseconds)

    # 优化建议：根据token使用情况提供建议
    if [ "$input" -gt 100000 ]; then
        suggestion=" (💡 建议：精简指令，减少输入token)"
    elif [ "$output" -gt 50000 ]; then
        suggestion=" (💡 建议：请求分段输出，减少输出token)"
    fi

    echo "[$timestamp] $name - Input: $input, Output: $output, Cost: \$$cost$suggestion" >> "$TOKEN_FILE"

    echo -e "${GREEN}✅ 已记录: $name${NC}"
    echo -e "${BLUE}💰 成本: \$$cost${NC}"
}

# 显示统计（优化读取）
show_stats() {
    if [ ! -f "$TOKEN_FILE" ]; then
        echo -e "${YELLOW}暂无记录${NC}"
        return
    fi

    # 优化：使用 awk 一次性计算，减少循环
    local stats=$(awk -F'Cost:\$' '/Cost:/ {cost+=$2; count++} END {printf "%s %s", cost, count}' "$TOKEN_FILE")
    total_cost=$(echo "$stats" | cut -d' ' -f1)
    count=$(echo "$stats" | cut -d' ' -f2)

    # 计算百分比和时长
    percentage=$(echo "scale=1; ($total_cost / $BUDGET) * 100" | bc)
    hours=$(echo "scale=2; $total_cost / $HOURLY_BUDGET" | bc)

    echo -e "${BLUE}📊 Token 统计${NC}"
    echo "────────────────────"
    echo "任务数:   $count"
    echo -e "总成本:   ${YELLOW}\$$total_cost${NC}"
    echo -e "预算:     $percentage% (\$$total_cost / \$$BUDGET)"
    echo -e "使用时长: ${YELLOW}$hours 小时${NC}"
    echo ""

    # 预算警告
    if (( $(echo "$percentage >= 80" | bc -l) )); then
        echo -e "${RED}⚠️  预算警告: 已使用 ${percentage}%${NC}"
    elif (( $(echo "$percentage >= 50" | bc -l) )); then
        echo -e "${YELLOW}⚠️  已使用 ${percentage}%${NC}"
    fi

    # 显示最近5条（使用 tail -n 5 优化读取）
    echo ""
    echo -e "${BLUE}最近记录 (最后5条)${NC}"
    tail -n 5 "$TOKEN_FILE" | sed 's/^/  /'
}

# 主逻辑
case "$1" in
    -h|--help)
        show_help
        ;;
    "")
        show_stats
        ;;
    *)
        if [ $# -ge 1 ]; then
            record_task "$@"
        else
            show_help
        fi
        ;;
esac
